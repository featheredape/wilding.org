---
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalPath?: string;
}

const {
  title,
  description = "The Wilding Foundation makes creative technology and artistic opportunity accessible to everyone, regardless of age, background, or financial means.",
  ogImage = "/img/og-image.png",
  ogType = "website",
  canonicalPath,
} = Astro.props;

const siteUrl = "https://wilding.org";
const canonical = canonicalPath ? `${siteUrl}${canonicalPath}` : undefined;
const fullOgImage = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;
---
<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="author" content="Ethan Wilding" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow" />
    {canonical && <link rel="canonical" href={canonical} />}

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="The Wilding Foundation" />
    <meta property="og:locale" content="en_CA" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />

    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Fraunces:opsz,wght@9..144,400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
    <Nav />
    <slot />
    <Footer />

    <script>
    (function () {
        // Navbar scroll shadow
        var navbar = document.querySelector("nav");
        if (navbar) {
            window.addEventListener("scroll", function () {
                navbar.classList.toggle("scrolled", window.scrollY > 10);
            });
        }

        // Mobile menu toggle
        var toggle = document.getElementById("navToggle");
        var links = document.getElementById("navLinks");
        if (toggle && links) {
            toggle.addEventListener("click", function () {
                links.classList.toggle("open");
            });
            links.querySelectorAll("a").forEach(function (a) {
                a.addEventListener("click", function () {
                    links.classList.remove("open");
                });
            });
        }

        // Scroll-triggered fade-in
        var observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
                if (entry.isIntersecting) entry.target.classList.add("visible");
            });
        }, { threshold: 0.1 });
        document.querySelectorAll(".card, .fade-in").forEach(function (el) {
            observer.observe(el);
        });
    })();
    </script>
</body>
</html>

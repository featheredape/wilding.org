---
import Base from "../../layouts/Base.astro";
import WorkshopCard from "../../components/WorkshopCard.astro";
import { getCollection } from "astro:content";

const allWorkshops = await getCollection("workshops");
const sorted = allWorkshops.sort((a, b) => {
  const af = a.data.hasApplicationForm ? 0 : 1;
  const bf = b.data.hasApplicationForm ? 0 : 1;
  if (af !== bf) return af - bf;
  return (a.data.startDate || "").localeCompare(b.data.startDate || "");
});
---
<Base title="Workshops - The Wilding Foundation" canonicalPath="/workshops">
    <div class="page-header fade-in">
        <h1>Workshops</h1>
        <p>Hands-on learning open to the whole island. All workshops are free or heavily subsidized.</p>
        <div class="header-line"></div>
    </div>

    <section class="workshops-listing">
        <div class="bento bento-flush">
            {sorted.map((ws) => (
                <WorkshopCard
                    title={ws.data.title}
                    description={ws.data.description}
                    category={ws.data.category}
                    date={ws.data.date}
                    time={ws.data.time}
                    spots={ws.data.spots}
                    slug={ws.id}
                    hasApplicationForm={ws.data.hasApplicationForm}
                    externalUrl={ws.data.externalUrl}
                />
            ))}
        </div>
    </section>
</Base>

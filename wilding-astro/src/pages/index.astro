---
import Base from "../layouts/Base.astro";
import WorkshopCard from "../components/WorkshopCard.astro";
import NewsletterCard from "../components/NewsletterCard.astro";
import { getCollection } from "astro:content";

const allNews = await getCollection("news");
const recentNews = allNews
  .sort((a, b) => b.data.sortDate.localeCompare(a.data.sortDate))
  .slice(0, 4);

const allWorkshops = await getCollection("workshops");
const featuredWorkshops = allWorkshops
  .filter((w) => w.data.featured)
  .sort((a, b) => {
    const af = a.data.hasApplicationForm ? 0 : 1;
    const bf = b.data.hasApplicationForm ? 0 : 1;
    if (af !== bf) return af - bf;
    return (a.data.startDate || "").localeCompare(b.data.startDate || "");
  })
  .slice(0, 3);
---
<Base title="The Wilding Foundation" canonicalPath="/">
    <section class="hero">
        <img src="/wflogo_main.svg" alt="The Wilding Foundation" class="hero-logo" />
    </section>

    <div class="bento">
        <!-- NEWS -->
        <div class="card span-8" id="news">
            <span class="card-label">News &amp; Media</span>
            <h2>Recent coverage</h2>
            <div class="news-list-compact">
                {recentNews.map((article) => (
                    <div class="news-row">
                        <span class="date">{article.data.date}</span>
                        <a href={`/news/${article.id}`}>{article.data.title}</a>
                    </div>
                ))}
            </div>
            <div style="margin-top: 1rem;">
                <a href="/news" class="link">See all coverage &rarr;</a>
            </div>
        </div>

        <!-- IMPACT -->
        <div class="card card-static span-4" style="display: flex; flex-direction: column; justify-content: center;">
            <span class="card-label">Impact</span>
            <div class="impact-stack">
                <div class="impact-item">
                    <div class="impact-number">$700k+</div>
                    <div class="impact-desc">FabLab investment</div>
                </div>
                <div class="impact-item">
                    <div class="impact-number">$200k</div>
                    <div class="impact-desc">Catalyst Grants</div>
                </div>
                <div class="impact-item">
                    <div class="impact-number">1,000+</div>
                    <div class="impact-desc">Youth participants 2025</div>
                </div>
            </div>
        </div>

        <!-- FABLAB -->
        <div class="card span-7" id="fablab">
            <img src="/img/ethan-julia-fablab.png" alt="Ethan and Julia at the FabLab" class="card-image" width="640" height="574" loading="lazy" />
            <span class="card-label">FabLab</span>
            <h2>A creative haven at the heart of the community</h2>
            <p>The <a href="https://saltspring.bc.libraries.coop/programs/fablab/">FabLab</a> at the Salt Spring Public Library is a community makerspace equipped with 3D printers, laser cutters, design software, and more. It offers islanders of all ages a place to learn, experiment, and create -- all free of charge.</p>
            <p>In 2025, the FabLab logged over 1,100 appointments and 3,600 drop-in visits, with STEAM program attendance over 1,000 participants.</p>
            <div class="card-quote">
                &ldquo;The Fab Lab is a very special place for my neurodivergent child and for our community in general.&rdquo;
            </div>
            <div class="stat-pills">
                <span class="stat-pill">97% booking rate</span>
                <span class="stat-pill">3,600+ drop-in visits in 2025</span>
            </div>
            <div style="margin-top: 1rem;">
                <a href="https://saltspring.bc.libraries.coop/programs/fablab/" class="link" target="_blank" rel="noopener">Explore the FabLab &rarr;</a>
            </div>
        </div>

        <!-- ROBOTICS -->
        <div class="card span-5" id="robotics">
            <img src="/img/giss-robotics-2026.png" alt="GISS Robotics team" class="card-image" width="700" height="525" loading="lazy" />
            <span class="card-label">GISS Robotics</span>
            <h2>Building robots, building futures</h2>
            <p>The Cyber/Scorpions team brings together students from grades 8 to 12 who design, build, and compete through VEX Robotics. The team has grown to 30 students and seven independently designed robots in a single season.</p>
        </div>

        <!-- WORKSHOPS -->
        {featuredWorkshops.map((ws) => (
            <WorkshopCard
                title={ws.data.title}
                description={ws.data.description}
                category={ws.data.category}
                date={ws.data.date}
                time={ws.data.time}
                spots={ws.data.spots}
                slug={ws.id}
                hasApplicationForm={ws.data.hasApplicationForm}
                externalUrl={ws.data.externalUrl}
            />
        ))}

        <!-- CATALYST -->
        <div class="card card-static span-6" id="catalyst">
            <span class="card-label">Catalyst Grants</span>
            <h2>Helping artists finish what they started</h2>
            <p>Grants of $3,000 to $10,000 for visual artists across the Southern Gulf Islands. More updates on the new grants to come.</p>
            <div class="card-quote">
                &ldquo;Smart arts funding&rdquo; &mdash; a model that directly supports the working artist at the moment of greatest need.
                <div class="card-quote-source"><a href="https://gulfislandsdriftwood.com/catalyst-grant-artists-announced/" target="_blank" rel="noopener">Gulf Islands Driftwood editorial</a></div>
            </div>
        </div>

        <!-- NEWSLETTER -->
        <NewsletterCard />
    </div>
</Base>

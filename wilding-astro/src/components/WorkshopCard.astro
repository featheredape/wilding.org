---
interface Props {
  title: string;
  description: string;
  category: string;
  date?: string;
  time?: string;
  spots?: number;
  slug: string;
  hasApplicationForm?: boolean;
  externalUrl?: string;
}

const { title, description, category, date, time, spots, slug, hasApplicationForm, externalUrl } = Astro.props;
const linkHref = hasApplicationForm
  ? `/workshops/${slug}`
  : externalUrl || `/workshops/${slug}`;
const isExternal = Boolean(externalUrl) && !hasApplicationForm;
---
<div class="card span-4">
    <span class="ws-tag">{category}</span>
    <h3>{title}</h3>
    <p>{description}</p>
    {(date || time || spots) && (
        <div class="ws-meta">
            {date && <span>{date}</span>}
            {time && <span>{time}</span>}
            {spots && <span>{spots} spots</span>}
        </div>
    )}
    <a href={linkHref} class="btn-sm" {...(isExternal ? { target: "_blank", rel: "noopener" } : {})}>
        {hasApplicationForm ? "Apply" : "Learn more"}
    </a>
</div>
